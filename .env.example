# Copy this file to `.env` and fill in real values locally.
# Process environment variables override values in `.env`.

# Required for real OpenAI-backed runs.
OPENAI_API_KEY=your_openai_api_key_here

# Optional override for the bounded orchestrator model.
# If unset, the repo falls back to the model configured in the agent TOML.
# MEIO_LLM_ORCHESTRATOR_MODEL=gpt-5.4-mini
